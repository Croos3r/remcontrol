<?xml version="1.0" encoding="utf-8"?>
<!-- remcontrol reaches the server over the LAN via cleartext ws://. Android 9+
     blocks cleartext by default; we permit it because the app only ever
     targets LAN hosts (QR / discover / manual all yield LAN addresses) and
     the PSK-ECDH handshake encrypts and authenticates every frame regardless
     of the TCP transport, so the payload is never actually in the clear.

     A scoped <domain-config> with CIDR ranges (10.0.0.0/8, etc.) does NOT
     work: Android's <domain> element matches literal hostnames or IP strings,
     not CIDR subnets, so a config like that silently blocks every real LAN
     IP and the WebSocket never opens. Permit cleartext globally instead. -->
<network-security-config>
  <base-config cleartextTrafficPermitted="true" />
</network-security-config>
